{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/consistent-type-imports": ["warn", { "fixStyle": "inline-type-imports" }]
  },
  "env": {
    "builtin": true
  }
}
